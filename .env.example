# Flask
SECRET_KEY=change-this-to-a-random-secret-key
FLASK_ENV=production
FLASK_DEBUG=0

# Database (SQLite by default — set USE_SQLITE=0 for MySQL)
USE_SQLITE=1
DB_HOST=localhost
DB_PORT=3306
DB_NAME=roadside_db
DB_USER=root
DB_PASSWORD=

# Google OAuth 2.0 — https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Maps API (Places, Distance Matrix) — https://console.cloud.google.com
GOOGLE_MAPS_API_KEY=

# OpenAI — https://platform.openai.com
OPENAI_API_KEY=

# Razorpay — https://dashboard.razorpay.com
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# App
PLATFORM_FEE_PERCENT=15
BASE_URL=http://localhost:5000
